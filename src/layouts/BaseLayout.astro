---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  /** Page-specific title. Omit on the home page to render just the site name. */
  title?: string;
  description?: string;
  ogImage?: string;
  /** Prevents indexing — use on 404, thank-you pages, etc. */
  noindex?: boolean;
  /**
   * JSON-LD structured data object. Serialised into a <script type="application/ld+json">.
   * Should be developer-supplied data only — never pass raw user input here.
   */
  jsonLD?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  jsonLD,
} = Astro.props;

// Build the canonical URL. Requires `site` to be set in astro.config.mjs.
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      canonicalURL={canonicalURL}
    />

    <!-- JSON-LD structured data -->
    {jsonLD && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
    )}

    <!-- Client-side routing with animated page transitions (Astro 6) -->
    <ClientRouter />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>

  <body>
    <!-- Skip-to-content — first focusable element, visible on keyboard focus -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
