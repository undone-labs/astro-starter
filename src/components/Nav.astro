---
const navLinks = [
  { label: 'Home',  href: '/'      },
  { label: 'About', href: '/about' },
];

const { pathname } = Astro.url;

function isActive(href: string): boolean {
  return href === '/' ? pathname === '/' : pathname.startsWith(href);
}
---

<!--
  Indicator logic:
  - A single <span> is absolutely positioned inside the <ul>
  - Alpine tracks hovered/focused link dimensions via getBoundingClientRect
  - On mouseleave it snaps back to the aria-current="page" link
  - Transition is disabled on init so the indicator doesn't slide in from 0,0
-->
<nav class="site-nav" aria-label="Main navigation" x-data="siteNav">

  <button
    class="nav-toggle"
    :class="{ 'is-open': open }"
    :aria-expanded="String(open)"
    aria-controls="nav-menu"
    aria-label="Toggle navigation menu"
    @click="open = !open"
    @keydown.escape="open = false"
  >
    <span class="hamburger" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <ul
    id="nav-menu"
    class="nav-menu"
    role="list"
    x-ref="menu"
    :class="{ 'is-open': open }"
    @keydown.escape="open = false"
    @mouseleave="reset()"
  >
    {navLinks.map(({ label, href }) => (
      <li>
        <a
          href={href}
          class="nav-link"
          aria-current={isActive(href) ? 'page' : undefined}
          @mouseenter="move($el)"
          @focus="move($el)"
        >
          {label}
        </a>
      </li>
    ))}

    <span
      class="nav-indicator"
      :class="{ 'is-ready': ready }"
      :style="`left: ${left}px; width: ${width}px`"
      aria-hidden="true"
    ></span>
  </ul>

</nav>

<!--
  is:inline so this runs before Alpine's bundled script, allowing
  alpine:init to register the component before Alpine processes the DOM.
-->
<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('siteNav', () => ({
      open:  false,
      left:  0,
      width: 0,
      ready: false,

      init() {
        this.$nextTick(() => {
          const active = this.$refs.menu.querySelector('[aria-current="page"]');
          if (active) this.move(active);
          // Enable transition only after the initial snap
          setTimeout(() => { this.ready = true; }, 50);
        });
      },

      move(el) {
        const menu = this.$refs.menu.getBoundingClientRect();
        const item = el.getBoundingClientRect();
        this.left  = item.left - menu.left;
        this.width = item.width;
      },

      reset() {
        const active = this.$refs.menu.querySelector('[aria-current="page"]');
        if (active) this.move(active);
        else this.width = 0;
      },
    }));
  });
</script>

<style>
  /* ---- Desktop --------------------------------------------------------- */

  .site-nav {
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav-toggle {
    display: none;
  }

  .nav-menu {
    position: relative; /* required for indicator absolute positioning */
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    position: relative;
    color: var(--sandstone);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-decoration: none;
    padding-block: 0.25rem;
    transition: color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link[aria-current='page'] {
    color: var(--tan);
  }

  /* Floating indicator — single element that slides between links */
  .nav-indicator {
    position: absolute;
    bottom: -2px;
    height: 2px;
    background: var(--tan);
    border-radius: 9999px;
    pointer-events: none;
    /* No transition on load — snaps to active link instantly */
  }

  .nav-indicator.is-ready {
    transition: left 250ms ease-out, width 250ms ease-out;
  }

  /* ---- Hamburger icon -------------------------------------------------- */

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 22px;
  }

  .hamburger span {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 9999px;
    transform-origin: center;
    transition:
      transform var(--transition-base),
      opacity  var(--transition-base);
  }

  .nav-toggle.is-open .hamburger span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .nav-toggle.is-open .hamburger span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle.is-open .hamburger span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* ---- Mobile ---------------------------------------------------------- */

  @media (max-width: 48em) {
    .nav-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      color: var(--bone);
      border-radius: 0.3rem;
      transition: background-color var(--transition-fast);
    }

    .nav-toggle:hover {
      background-color: var(--woodsmoke);
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: calc(100% + 0.75rem);
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      min-width: 180px;
      background: var(--woodsmoke);
      border: 1px solid var(--tuna);
      border-radius: 0.45rem;
      box-shadow: var(--shadow-lg);
      padding-block: 0.5rem;
      z-index: var(--z-above);
    }

    .nav-menu.is-open {
      display: flex;
    }

    .nav-menu li {
      width: 100%;
    }

    .nav-link {
      display: block;
      padding: 0.75rem 1rem;
    }

    .nav-link[aria-current='page'] {
      background-color: var(--woodsmoke);
      color: var(--bone);
    }

    .nav-indicator {
      display: none;
    }
  }
</style>
