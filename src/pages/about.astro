---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadPage } from '../lib/content';

const { meta, content } = loadPage('about');
const c = content as {
  heading: string;
  paragraphs: string[];
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
>
  <section class="page-section">
    <div class="container">
      <h1>{c.heading}</h1>
      <div class="markdown">
        {c.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    padding-block: 4rem;
  }

  h1 {
    margin-bottom: 2rem;
  }

  .markdown {
    max-width: 68ch;
  }
</style>
